# FinSight Environment Variables Example
# Copy this file to .env and fill in your API keys

# LLM API
GEMINI_PROXY_API_KEY=
GEMINI_PROXY_API_BASE=

# Stock Data APIs
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
MASSIVE_API_KEY=
IEX_CLOUD_API_KEY=
TIINGO_API_KEY=
TWELVE_DATA_API_KEY=
MARKETSTACK_API_KEY=
EODHD_API_KEY=
SEC_USER_AGENT=FinSight admin@finsight.app

# Financial Modeling Prep API (免费版 250 次/天)
# 用于获取：分部收入、ETF 板块权重、ETF 持仓、指数成分股
# 注册: https://financialmodelingprep.com/developer/docs/
FMP_API_KEY=

# Search APIs
TAVILY_API_KEY=
EXA_API_KEY=

# Symbol Lookup
OPENFIGI_API_KEY=

# Macro Data
FRED_API_KEY=

# Monitoring
LANGSMITH_API_KEY=
ENABLE_LANGSMITH=false
LANGSMITH_PROJECT=FinSight

# LangFuse 链路追踪（可选，需注册 https://cloud.langfuse.com）
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Email Alerts (Optional)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# Scheduler
PRICE_ALERT_SCHEDULER_ENABLED=false
NEWS_ALERT_SCHEDULER_ENABLED=false
RISK_ALERT_SCHEDULER_ENABLED=false
RISK_ALERT_INTERVAL_MINUTES=60
RISK_ALERT_COOLDOWN_MINUTES=180

# LLM Rate-Limit Retry (endpoint round-robin failover)
# On 429/quota errors, rotates to the next configured endpoint via llm_factory.
# With multiple endpoints, 6 attempts is usually sufficient for full rotation.
LLM_RATE_LIMIT_RETRY_MAX_ATTEMPTS=6
LLM_RATE_LIMIT_RETRY_SLEEP_SECONDS=5
LLM_RATE_LIMIT_RETRY_JITTER_SECONDS=2
LLM_RATE_LIMIT_RETRY_ACQUIRE_TIMEOUT_SECONDS=3600

# Quality & Guardrails
DATA_CONTEXT_MAX_SKEW_HOURS=24
BUDGET_MAX_TOOL_CALLS=24
BUDGET_MAX_ROUNDS=12
BUDGET_MAX_SECONDS=120
CHAT_HISTORY_MAX_MESSAGES=12
CACHE_JITTER_RATIO=0.1
CACHE_NEGATIVE_TTL=60
PRICE_CB_FAILURE_THRESHOLD=5
PRICE_CB_RECOVERY_TIMEOUT=60
NEWS_CB_FAILURE_THRESHOLD=3
NEWS_CB_RECOVERY_TIMEOUT=180
LOG_LEVEL=INFO

# Security Gate
# ⚠️  PRODUCTION: Set API_AUTH_ENABLED=true and configure API_AUTH_KEYS!
# ⚠️  PRODUCTION: Set RATE_LIMIT_ENABLED=true to prevent abuse!
API_AUTH_ENABLED=false
API_AUTH_KEYS=
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_WINDOW_SECONDS=60

# CORS / Public routes / Session context lifecycle
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=false
API_PUBLIC_PATHS=/health,/docs,/openapi.json,/redoc
SESSION_CONTEXT_TTL_MINUTES=240
SESSION_CONTEXT_MAX_THREADS=1000

# Frontend runtime API base
VITE_API_BASE_URL=http://127.0.0.1:8000

# LangGraph checkpointer persistence (production hardening)
LANGGRAPH_CHECKPOINTER_BACKEND=sqlite
LANGGRAPH_CHECKPOINTER_ALLOW_MEMORY_FALLBACK=false
# LANGGRAPH_CHECKPOINTER_BACKEND=postgres
# LANGGRAPH_CHECKPOINT_POSTGRES_DSN=postgresql://user:pass@host:5432/db
# LANGGRAPH_CHECKPOINT_POSTGRES_PIPELINE=false

# RAG v2 (Hybrid Retrieval)
# backend: postgres | memory | auto (auto: use postgres when DSN exists)
RAG_V2_BACKEND=auto
# Production recommended: false (disallow silent fallback)
RAG_V2_ALLOW_MEMORY_FALLBACK=true
# Optional override; leave empty to follow embedding dimension automatically
RAG_V2_VECTOR_DIM=
RAG_V2_RRF_K=60
# Leave empty to reuse LANGGRAPH_CHECKPOINT_POSTGRES_DSN
RAG_V2_POSTGRES_DSN=
RAG_V2_TOP_K=18
RAG_V2_RERANK_TOP_N=8
RAG_V2_NEWS_TTL_HOURS=168
RAG_V2_EPHEMERAL_TTL_HOURS=12

# Embedding / Reranker
RAG_EMBEDDING=bge-m3
BGE_M3_DEVICE=cpu
BGE_M3_MAX_LENGTH=512
RAG_HASH_DIM=96
RAG_RERANKER=bge-reranker
RAG_RERANKER_MAX_LENGTH=512

# LangGraph Pipeline Modes (Phase B: Real AI)
# Planner: stub = deterministic rule engine | llm = LLM-generated PlanIR (with _enforce_policy + stub fallback)
LANGGRAPH_PLANNER_MODE=stub
LANGGRAPH_PLANNER_TEMPERATURE=0.2
# Execute: false = dry_run (skip tools/agents) | true = real API calls (yfinance/FMP/Tavily/Exa)
LANGGRAPH_EXECUTE_LIVE_TOOLS=false
# Synthesize: stub = deterministic template | llm = LLM JSON vars + stub merge | narrative = full markdown report
LANGGRAPH_SYNTHESIZE_MODE=stub
LANGGRAPH_SYNTHESIZE_TEMPERATURE=0.2

# Dashboard AI Insights Engine (Phase F)
# true = enable Digest Agent insights at /api/dashboard/insights
# false = endpoint returns empty insights, frontend falls back to deterministic scores
INSIGHTS_ENABLED=true
# Agent temperature (shared across all 6 specialist agents)
LANGGRAPH_AGENT_TEMPERATURE=0.2

# Report agent limits
LANGGRAPH_REPORT_MAX_AGENTS=6
LANGGRAPH_REPORT_MIN_AGENTS=2
# Deep search escalation (lower = more aggressive)
LANGGRAPH_ESCALATION_MIN_CONFIDENCE=0.85

# Planner Prompt/Plan A/B experiment
LANGGRAPH_PLANNER_AB_ENABLED=false
LANGGRAPH_PLANNER_AB_SPLIT=50
LANGGRAPH_PLANNER_AB_SALT=planner-ab-v1
