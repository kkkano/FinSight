# FinSight — Server Environment Template
# Copy to .env.server and fill in real values before deploying:
#   cp .env.server.example .env.server
#   vim .env.server
#
# This file is tracked in git (no real secrets here).
# .env.server is in .gitignore and must NEVER be committed.

# ── PostgreSQL (docker-compose managed) ─────────────────────────────────────
POSTGRES_DB=finsight
POSTGRES_USER=finsight
POSTGRES_PASSWORD=your_strong_password_here

# ── LLM (OpenAI-compatible API) ──────────────────────────────────────────────
# Default endpoint is pre-configured via docker-compose.yml.
# Fill the real key in .env.server on the server; never commit it.
OPENAI_COMPATIBLE_API_KEY=your_openai_compatible_key_here
OPENAI_COMPATIBLE_API_BASE=https://token-plan-cn.xiaomimimo.com/v1
OPENAI_COMPATIBLE_MODEL=mimo-v2.5-pro

# ── Build network mirrors ───────────────────────────────────────────────────
# Used only during Docker image build; override if your server has faster PyPI access.
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# ── Financial Data APIs ──────────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=your_key_here
FINNHUB_API_KEY=your_key_here
TWELVE_DATA_API_KEY=your_key_here
FMP_API_KEY=your_key_here
OPENFIGI_API_KEY=your_key_here
EODHD_API_KEY=your_key_here
FRED_API_KEY=your_key_here

# ── Search & Web ─────────────────────────────────────────────────────────────
TAVILY_API_KEY=your_key_here
EXA_API_KEY=your_key_here

# ── LangSmith (optional, tracing) ───────────────────────────────────────────
LANGSMITH_API_KEY=lsv2_pt_your_key_here
ENABLE_LANGSMITH=true
LANGSMITH_PROJECT=FinSight

# ── LangFuse (optional, observability) ──────────────────────────────────────
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-your_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=your_email@gmail.com
SEC_USER_AGENT=FinSight your_email@gmail.com

# ── Third-party extras ───────────────────────────────────────────────────────
MASSIVE_API_KEY=your_key_here

# ── 证据研究与协议适配器 ────────────────────────────────────────────────────
RESEARCH_LEDGER_ENABLED=true
QUERY_COVERAGE_ENABLED=true
DEBATE_GRAPH_ENABLED=false
SEC_HOLDINGS_ENABLED=true
# 协议适配器默认关闭，只暴露只读工具
MCP_SERVER_ENABLED=false
A2A_SERVER_ENABLED=false
A2A_PUBLIC_URL=

# ── Scheduler ────────────────────────────────────────────────────────────────
PRICE_ALERT_SCHEDULER_ENABLED=true
NEWS_ALERT_SCHEDULER_ENABLED=true
PRICE_ALERT_COOLDOWN_MINUTES=60

# ── Bloomberg RSS (public URLs, safe to keep as-is) ──────────────────────────
BLOOMBERG_RSS_URLS=https://feeds.bloomberg.com/markets/news.rss,https://feeds.bloomberg.com/technology/news.rss,https://feeds.bloomberg.com/politics/news.rss

# ── Schema Router ────────────────────────────────────────────────────────────
USE_SCHEMA_ROUTER=true

# ── LangGraph ────────────────────────────────────────────────────────────────
LANGGRAPH_PLANNER_MODE=llm
LANGGRAPH_SYNTHESIZE_MODE=llm
FINSIGHT_INTENT_CONTRACT_MODE=enforce
FINSIGHT_CONTEXT_ROUTER_ENABLED=true
FINSIGHT_CONTEXT_ROUTER_TIMEOUT_SEC=90
FINSIGHT_CONTEXT_ROUTER_MAX_TOKENS=2200
FINSIGHT_CHAT_MULTI_TICKER_RESEARCH_LIMIT=3
FINSIGHT_CONTEXT_REPLY_TIMEOUT_SEC=120
FINSIGHT_CONTEXT_REPLY_MAX_TOKENS=3000
LANGGRAPH_PLANNER_CHAT_TIMEOUT_SEC=150
LANGGRAPH_PLANNER_CHAT_MAX_TOKENS=3000
LANGGRAPH_PLANNER_CHAT_MAX_ATTEMPTS=2
LANGGRAPH_PLANNER_CHAT_ACQUIRE_TIMEOUT_SEC=120
LANGGRAPH_PLANNER_REPORT_TIMEOUT_SEC=240
LANGGRAPH_PLANNER_REPORT_MAX_TOKENS=6000
LANGGRAPH_PLANNER_REPORT_MAX_ATTEMPTS=3
LANGGRAPH_PLANNER_REPORT_ACQUIRE_TIMEOUT_SEC=180
LANGGRAPH_SYNTHESIZE_TIMEOUT_SEC=150
LANGGRAPH_SYNTHESIZE_MAX_TOKENS=3000
LANGGRAPH_SYNTHESIZE_MAX_ATTEMPTS=2
LANGGRAPH_SYNTHESIZE_ACQUIRE_TIMEOUT_SEC=120
LANGGRAPH_SYNTHESIZE_REPORT_TIMEOUT_SEC=800
LANGGRAPH_SYNTHESIZE_REPORT_MAX_TOKENS=6000
LANGGRAPH_SYNTHESIZE_REPORT_MAX_ATTEMPTS=3
LANGGRAPH_SYNTHESIZE_REPORT_ACQUIRE_TIMEOUT_SEC=180
LANGGRAPH_EXECUTE_LIVE_TOOLS=true
LANGGRAPH_REPORT_MAX_AGENTS=6
LANGGRAPH_REPORT_MIN_AGENTS=2
LANGGRAPH_ESCALATION_MIN_CONFIDENCE=0.85

# ── Agent LLM 分析 ──────────────────────────────────────────────────────────
# 开启后各 agent (Price/News/Fundamental/Technical/Macro) 的确定性摘要
# 会经过 LLM 分析层加工，输出 200-500 字专业分析而非裸数据。
# 关闭时 agent 只做 API 取数据 + 简单格式化，输出内容较短。
FINSIGHT_FORCE_AGENT_RESEARCH_CONFIG=true
AGENT_LLM_ANALYZE_ENABLED=true
TECHNICAL_AGENT_LLM_SUMMARY_ENABLED=1
AGENT_LLM_ANALYZE_TIMEOUT_SECONDS=30
AGENT_LLM_ANALYZE_CALL_TIMEOUT_SECONDS=60
BASE_AGENT_REFLECTION_TOKEN_TIMEOUT_SECONDS=30
# 反思循环次数 (0=关闭)。开启会增加 2 次 LLM 调用/agent，
# API 限流严格时建议设为 0，仅保留 _first_summary 的 LLM 分析。
BASE_AGENT_MAX_REFLECTIONS=0

# ── LLM Rate Limit & Retry ───────────────────────────────────────────────────
LLM_ENDPOINT_DEFAULT_COOLDOWN_SEC=30
LLM_RATE_LIMIT_RETRY_ENABLED=true
LLM_RATE_LIMIT_RETRY_MAX_ATTEMPTS=4
LLM_RATE_LIMIT_RETRY_SLEEP_SECONDS=1
LLM_RATE_LIMIT_RETRY_JITTER_SECONDS=0.2
LLM_RATE_LIMIT_RETRY_ACQUIRE_TIMEOUT_SECONDS=15
DEEPSEARCH_LLM_TOKEN_TIMEOUT_SECONDS=1000
LANGGRAPH_DEEP_SEARCH_AGENT_TIMEOUT_SECONDS=1000
DEEPSEARCH_HTTP_RETRIES=0
DEEPSEARCH_FETCH_TIMEOUT_SECONDS=10
JINA_READER_TIMEOUT=6
WAYBACK_TIMEOUT=6

# ── RAG V2 (Postgres pgvector — docker-compose overrides DSN automatically) ──
# These two are set in docker-compose.yml via environment: section.
# Do NOT override here unless you want a separate external postgres.
# RAG_V2_BACKEND=postgres
# RAG_V2_POSTGRES_DSN=postgresql+asyncpg://finsight:pass@postgres:5432/finsight

RAG_V2_ALLOW_MEMORY_FALLBACK=true
RAG_V2_VECTOR_DIM=1024
RAG_V2_RRF_K=60
RAG_V2_TOP_K=18
RAG_V2_RERANK_TOP_N=8
RAG_V2_NEWS_TTL_HOURS=168
RAG_V2_EPHEMERAL_TTL_HOURS=12

# ── Embedding & Reranker ─────────────────────────────────────────────────────
RAG_EMBEDDING=bge-m3
BGE_M3_DEVICE=cpu
BGE_M3_MAX_LENGTH=512
RAG_HASH_DIM=96
RAG_RERANKER=bge-reranker
RAG_RERANKER_MAX_LENGTH=512

# ── Eval LLM (used only in tests/rag_quality*) ───────────────────────────────
LLM_API_KEY=your_eval_api_key_here
LLM_API_BASE=https://api.siliconflow.cn/v1
EVAL_LLM_MODEL=deepseek-ai/DeepSeek-V3

# Supabase Auth (shared by frontend build + backend runtime verification)
# Backend /diagnostics/rag/* now validates Authorization: Bearer <access_token>
# against Supabase Auth /auth/v1/user, so backend must also know the same project.
# Recommended: keep SUPABASE_* and VITE_SUPABASE_* pointing to the same project.
# Example:
# SUPABASE_URL=https://<your-project-ref>.supabase.co
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
RAG_OBSERVABILITY_AUTH_CACHE_SECONDS=60
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
